# ----------------------------------------------------------------------
# Git Roulette - .gitignore
# ----------------------------------------------------------------------

# Dependencies
node_modules/

# Environment Variables (CRITICAL: Do not commit your target paths/secrets)
.env
.env.*
!.env.example

# Compiled output (If you ever build the TypeScript)
dist/
build/
out/

# OS-specific files (Because you are on a Mac)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Logs and Debugging
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git Roulette Specific (Ignore your dummy files and test repos)
roulette.log
initial.txt
some-safe-dummy-repo/